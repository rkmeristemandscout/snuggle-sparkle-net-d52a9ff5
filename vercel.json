{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": false,
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/",
      "destination": "https://snuggle-sparkle-net.lovable.app/"
    },
    {
      "source": "/:path*",
      "destination": "https://snuggle-sparkle-net.lovable.app/:path*"
    }
  ]
}
